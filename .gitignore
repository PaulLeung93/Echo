# Python bytecode caches from scripts/ (py_compile, imports)
__pycache__/
*.pyc

# Firebase emulator / CLI artifacts (rules and config are tracked; these are not)
.firebase/
*-debug.log
firebase-debug.log
firestore-debug.log
ui-debug.log