rules_version = '2';

// Echo Firestore security rules.
//
// Threat model & guarantees:
//   - Authorship cannot be spoofed: posts/comments are owned by the stable
//     Firebase Auth uid (`authorId`), set to request.auth.uid at create time.
//   - Guests (anonymous auth) can read but cannot write.
//   - POIs are seeded server-side and are read-only to clients, except the
//     denormalized `commentCount` which may move by one when commenting.
//   - Comments are immutable once written; only the author may delete.
//
// Known limitation (tracked in ROADMAP Phase 3): the 5km proximity rule and
// per-user rate limiting are NOT enforced here. Firestore rules have no trusted
// source for the caller's physical location, and per-user time-window limits
// need server state. Those require a Cloud Function (or App Check + callable)
// and remain client-side-gated only until then.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Email/password and Google users only — excludes anonymous "guest" sessions.
    function isNotAnonymous() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Keys whose values differ between the stored doc and the incoming write.
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // The caller's chosen handle from their profile. Used to validate that a
    // post/comment's denormalized `username` is the author's real handle (not
    // spoofed). Requires the user to have completed their profile (the app's
    // completion gate guarantees this before they can post/comment).
    function profileUsername() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username;
    }

    // A comment document is well-formed and attributed to the caller.
    function isValidNewComment() {
      let d = request.resource.data;
      return d.authorId == request.auth.uid
        && d.username == profileUsername()
        && d.message is string
        && d.message.size() > 0
        && d.message.size() <= 1000
        && d.timestamp is int
        && d.keys().hasOnly(['authorId', 'username', 'authorPhotoUrl', 'message', 'timestamp']);
    }

    // The like array changed by exactly the caller's own uid (added or removed),
    // with nothing else touched. Uses set semantics to ignore order/duplicates.
    function togglesOwnLikeOnly() {
      let before = resource.data.get('likes', []).toSet();
      let after = request.resource.data.likes.toSet();
      let me = [request.auth.uid].toSet();
      return (after.difference(before) == me && before.difference(after).size() == 0)
          || (before.difference(after) == me && after.difference(before).size() == 0);
    }

    // commentCount moved by exactly +/-1 (a single comment added or removed).
    function commentCountMovedByOne() {
      let before = resource.data.get('commentCount', 0);
      let after = request.resource.data.commentCount;
      // Move by exactly +/-1, and never let the counter go negative.
      return (after == before + 1 || after == before - 1) && after >= 0;
    }

    // postCount moved by exactly +/-1 (a single post added to or removed from a POI
    // thread). The -1 path is normally performed by the cascade-delete Cloud Function
    // (admin, bypasses rules); +1 is the client's create batch.
    function postCountMovedByOne() {
      let before = resource.data.get('postCount', 0);
      let after = request.resource.data.postCount;
      return (after == before + 1 || after == before - 1) && after >= 0;
    }

    // A POI post must reference a real POI and carry that POI's actual name, so the
    // denormalized `poiName` shown on the feed badge can't be spoofed. Ordinary posts
    // (no `poiId`) pass trivially.
    function isValidPoiRef() {
      let d = request.resource.data;
      return !('poiId' in d) || (
        exists(/databases/$(database)/documents/pois/$(d.poiId))
        && d.poiName == get(/databases/$(database)/documents/pois/$(d.poiId)).data.name
      );
    }

    // ----- Posts -----
    match /posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isNotAnonymous()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.username == profileUsername()
        && request.resource.data.id == postId
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 1000
        && request.resource.data.timestamp is int
        && request.resource.data.tags is list
        && request.resource.data.likeCount == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.likes.size() == 0
        && request.resource.data.keys().hasOnly([
             'id', 'authorId', 'username', 'authorPhotoUrl', 'message', 'timestamp',
             'tags', 'likeCount', 'commentCount', 'likes',
             'latitude', 'longitude', 'geohash', 'poiId', 'poiName'
           ])
        && isValidPoiRef();

      // All post writes require a real (non-guest) account. Guests can read only.
      allow update: if isNotAnonymous() && (
        // (a) Author edits only the message body.
        (request.auth.uid == resource.data.authorId
          && changedKeys().hasOnly(['message'])
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 1000)
        // (b) A signed-in user toggles their own like; likeCount stays consistent.
        || (changedKeys().hasOnly(['likes', 'likeCount'])
          && request.resource.data.likeCount == request.resource.data.likes.size()
          && togglesOwnLikeOnly())
        // (c) Comment add/remove moves the denormalized commentCount by one.
        || (changedKeys().hasOnly(['commentCount']) && commentCountMovedByOne())
      );

      allow delete: if isNotAnonymous() && request.auth.uid == resource.data.authorId;

      // ----- Comments on a post -----
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isNotAnonymous() && isValidNewComment();
        allow update: if false; // comments are immutable
        allow delete: if isNotAnonymous() && request.auth.uid == resource.data.authorId;
      }
    }

    // ----- Points of Interest (seeded server-side) -----
    // A POI is now a thread of posts (see /posts with a `poiId`); it no longer carries
    // its own comments subcollection.
    match /pois/{poiId} {
      allow read: if isSignedIn();
      allow create, delete: if false; // managed out-of-band, never by clients

      // The denormalized postCount may change by +/-1 (a single post added to or
      // removed from this POI's thread; posting requires a real account, so guests
      // never reach this). The +1 (new echo) batch also stamps lastPostAt to the
      // server time so the map can show a "recently active" glow; that timestamp must
      // equal request.time so it can't be backdated or set to the future.
      allow update: if isNotAnonymous()
        && changedKeys().hasOnly(['postCount', 'lastPostAt'])
        && postCountMovedByOne()
        && (!changedKeys().hasAny(['lastPostAt']) || request.resource.data.lastPostAt == request.time);
    }

    // Valid username: 3–20 chars, lowercase letters/digits/underscore, no
    // leading/trailing underscore (mirrors isValidUsername in the app).
    function isValidUsername(name) {
      return name is string && name.matches('^[a-z0-9][a-z0-9_]{1,18}[a-z0-9]$');
    }

    // A favorites change is well-formed: the map stays within the cap, and the write
    // either adds exactly one slot (stamped to request.time so it can't be backdated)
    // or removes exactly one slot whose 7-day hold has already elapsed. Existing slots'
    // timestamps are immutable. This keeps favorites scarce + sticky so they can't be
    // cycled to post into arbitrary POI threads beyond the proximity radius.
    function favoritesChangeValid() {
      let before = resource.data.get('favorites', {});
      let after = request.resource.data.favorites;
      let added = after.keys().removeAll(before.keys());
      let removed = before.keys().removeAll(after.keys());
      return after is map
        && after.size() <= 3
        && after.diff(before).changedKeys().size() == 0
        && (
             (added.size() == 1 && removed.size() == 0
               && after[added[0]] == request.time)
          || (removed.size() == 1 && added.size() == 0
               && before[removed[0]] is timestamp
               && before[removed[0]] < request.time - duration.value(7, 'd'))
           );
    }

    // ----- User profiles -----
    match /users/{uid} {
      // Any signed-in user can read profiles (to show names/usernames).
      allow read: if isSignedIn();

      allow create: if isNotAnonymous()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && isValidUsername(request.resource.data.username)
        && request.resource.data.firstName is string
        && request.resource.data.firstName.size() > 0
        && request.resource.data.lastName is string
        && request.resource.data.bio is string
        && request.resource.data.bio.size() <= 160
        && request.resource.data.keys().hasOnly(
             ['uid', 'username', 'firstName', 'lastName', 'bio', 'createdAt']
           );

      // Owner-only updates: (a) edit name + bio, (b) change the avatar photoUrl, or
      // (c) change the blocked list. username/uid/email are immutable. Split so each
      // kind of write (which carries only its own keys) isn't rejected by the others.
      allow update: if isNotAnonymous()
        && uid == request.auth.uid
        && (
          (changedKeys().hasOnly(['firstName', 'lastName', 'bio'])
            && request.resource.data.firstName is string
            && request.resource.data.firstName.size() > 0
            && request.resource.data.bio is string
            && request.resource.data.bio.size() <= 160)
          || (changedKeys().hasOnly(['photoUrl'])
            && request.resource.data.photoUrl is string)
          || (changedKeys().hasOnly(['blockedUserIds'])
            && request.resource.data.blockedUserIds is list)
          || (changedKeys().hasOnly(['favorites'])
            && favoritesChangeValid())
        );

      // Owner may delete their own profile (account deletion).
      allow delete: if isNotAnonymous() && uid == request.auth.uid;

      // ----- Follow graph -----
      // A user manages only their own `following` list (the single source of truth
      // for an edge). A Cloud Function mirrors the `followers` entry onto the target
      // and maintains the denormalized follower/following counts, so clients never
      // write `followers` or the count fields. Self-follow is barred, the target must
      // exist, and a block either direction prevents the follow.
      match /following/{targetUid} {
        allow read: if isSignedIn();
        allow create: if isNotAnonymous()
          && uid == request.auth.uid
          && targetUid != uid
          && exists(/databases/$(database)/documents/users/$(targetUid))
          && request.resource.data.keys().hasOnly(['createdAt'])
          && request.resource.data.createdAt == request.time
          && !(request.auth.uid in
               get(/databases/$(database)/documents/users/$(targetUid)).data.get('blockedUserIds', []))
          && !(targetUid in
               get(/databases/$(database)/documents/users/$(uid)).data.get('blockedUserIds', []));
        allow delete: if isNotAnonymous() && uid == request.auth.uid;
        allow update: if false;
      }

      // The followers mirror is function-maintained only; clients may read it.
      match /followers/{followerUid} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // ----- Username reservations (enforce uniqueness) -----
    // Doc id is the lowercased handle; the doc just maps it to a uid. Create
    // only succeeds on a non-existent doc (a set on an existing one is an update,
    // which is denied), so handles are unique and permanent.
    match /usernames/{handle} {
      allow read: if isSignedIn();
      allow create: if isNotAnonymous()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid'])
        && isValidUsername(handle);
      allow update: if false;
      // Owner may release their handle (account deletion).
      allow delete: if isNotAnonymous() && resource.data.uid == request.auth.uid;
    }

    // ----- Content reports (user-submitted; triaged out-of-band) -----
    // Write-only for clients: any signed-in real user may file a report, but no
    // client can read/modify/delete them. Moderation happens in the console.
    match /reports/{reportId} {
      allow read, update, delete: if false;
      allow create: if isNotAnonymous()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.type in ['post', 'comment', 'user']
        && request.resource.data.targetId is string
        && request.resource.data.targetId.size() > 0
        && request.resource.data.targetAuthorId is string
        && request.resource.data.reason is string
        && request.resource.data.keys().hasOnly(
             ['reporterId', 'type', 'targetId', 'targetAuthorId',
              'contextId', 'reason', 'timestamp']
           );
    }

    // Deny everything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
