# Release signing template — copy to `keystore.properties` (gitignored) and fill in.
#
# 1. Create an upload keystore (once):
#      keytool -genkey -v -keystore echo-upload.jks -alias echo-upload \
#        -keyalg RSA -keysize 2048 -validity 10000
#    Store the .jks OUTSIDE the repo (or it's gitignored here) and back it up —
#    losing it (without Play App Signing enrollment) means you can't update the app.
#
# 2. Fill these in and save as `keystore.properties` in the project root.
#
# storeFile can be absolute or relative to the app/ module.
storeFile=../echo-upload.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=echo-upload
keyPassword=YOUR_KEY_PASSWORD
